{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "noImplicitAny": false,
    "lib": ["es2020", "dom", "WebWorker"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./",
    "rootDir": "./",
    "moduleResolution": "node"
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}